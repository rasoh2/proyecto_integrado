{
  "openapi": "3.0.0",
  "info": {
    "title": "Alke Wallet API",
    "version": "1.0.0",
    "description": "API RESTful para el sistema de Blog/Registro de usuarios con integración Frontend-Backend."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "summary": "Iniciar sesión",
        "description": "Autentica un usuario y devuelve un token JWT.",
        "tags": ["Autenticación"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "test@test.com" },
                  "password": { "type": "string", "example": "123456" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login exitoso y token generado" },
          "401": { "description": "Credenciales inválidas" }
        }
      }
    },
    "/api/profile/me": {
      "get": {
        "summary": "Ver mi perfil",
        "description": "Obtiene la información del usuario autenticado.",
        "tags": ["Perfil"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Perfil obtenido" },
          "401": { "description": "No autorizado (Falta Token)" }
        }
      }
    },
    "/api/profile/avatar": {
      "put": {
        "summary": "Subir Avatar",
        "description": "Sube y asocia una foto de perfil al usuario autenticado (acepta JPG/PNG maxSize 2MB).",
        "tags": ["Perfil"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "avatar": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Avatar subido exitosamente" }
        }
      }
    },
    "/api/users": {
      "get": {
        "summary": "Listar usuarios",
        "tags": ["Usuarios"],
        "responses": {
          "200": { "description": "Lista de usuarios obtenida" }
        }
      }
    },
    "/api/posts": {
      "get": {
        "summary": "Listar posts",
        "tags": ["Posts"],
        "responses": {
          "200": { "description": "Lista de posts" }
        }
      },
      "post": {
        "summary": "Crear un post",
        "tags": ["Posts"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string", "example": "Mi primer post" },
                  "content": {
                    "type": "string",
                    "example": "Contenido del post"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Post creado" }
        }
      }
    }
  }
}
