  "item": [
    {
      "name": "AUTH",
      "item": [
        {
          "name": "Register - Crear Usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseJson = pm.response.json();",
                  "",
                  "pm.test('Status code is 201 - Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has success status', function () {",
                  "  pm.expect(responseJson.status).to.equal('success');",
                  "});",
                  "",
                  "pm.test('Response contains user data with id, name, email', function () {",
                  "  pm.expect(responseJson.data).to.have.all.keys('id', 'name', 'email', 'role', 'active', 'createdAt', 'updatedAt');",
                  "});",
                  "",
                  "pm.test('User role is correctly set', function () {",
                  "  pm.expect(responseJson.data.role).to.equal('user');",
                  "});",
                  "",
                  "pm.test('Response time is less than 1000ms', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate random email per request",
                  "const timestamp = Date.now();",
                  "pm.environment.set('user_email', `user_${timestamp}@test.com`);",
                  "pm.environment.set('user_name', `Test User ${timestamp}`);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{user_name}}\",\n  \"email\": \"{{user_email}}\",\n  \"password\": \"password123\",\n  \"role\": \"user\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login - Obtener JWT Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseJson = pm.response.json();",
                  "",
                  "pm.test('Status code is 200 - OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains JWT token', function () {",
                  "  pm.expect(responseJson.token).to.be.a('string');",
                  "  pm.expect(responseJson.token).to.have.lengthOf.above(20);",
                  "});",
                  "",
                  "pm.test('Store token for subsequent requests', function () {",
                  "  pm.environment.set('jwt_token', responseJson.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
